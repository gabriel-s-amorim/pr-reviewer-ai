# ── Local dry-run (fixture testing without a real GitHub App) ─────────────
# With DRY_RUN=true, only GITHUB_WEBHOOK_SECRET is strictly required.
PR_ASSISTANT_DRY_RUN=true
GITHUB_WEBHOOK_SECRET=dev-webhook-secret

# ── GitHub App (required when PR_ASSISTANT_DRY_RUN=false) ─────────────────
# App ID: GitHub → Settings → Developer settings → GitHub Apps → your app
GITHUB_APP_ID=

# Private key PEM. Prefer one of:
# 1) Escaped newlines in a single line: -----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END...
# 2) Base64 of the whole .pem file
GITHUB_APP_PRIVATE_KEY=

# Webhook secret you chose when creating the GitHub App
# GITHUB_WEBHOOK_SECRET=...

# ── Anthropic (required when not in dry-run) ──────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ── Upstash Redis (required when not in dry-run) ──────────────────────────
# Console: https://console.upstash.com → Redis → REST URL + REST TOKEN
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Optional ──────────────────────────────────────────────────────────────
# Extra ignore globs (comma-separated), merged with defaults
# DIFF_IGNORE_PATTERNS=*.snap,fixtures/**

# Override for scripts/test-webhook.ts
# WEBHOOK_URL=http://localhost:3000/api/webhooks/github
